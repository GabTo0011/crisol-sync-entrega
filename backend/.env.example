# ============================================================
# Crisol Sync Backend — Variables de Entorno
# ============================================================
# Copia este archivo como .env y completa con valores reales.
# NUNCA subir .env con valores reales a Git.
# ============================================================

# --- General ---
NODE_ENV=development
PORT=3000

# --- Frontend (CORS) ---
# Separar múltiples origins con coma: http://localhost:5173,https://mi-app.vercel.app
FRONTEND_URL=http://localhost:5173

# --- Base de datos (Supabase PostgreSQL) ---
# DATABASE_URL: conexión pooled (puerto 6543) — usada en runtime
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# DIRECT_URL: conexión directa (puerto 5432) — usada para migraciones Prisma
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# --- Supabase ---
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- JWT ---
JWT_SECRET=tu-secreto-seguro-aqui
JWT_EXPIRES_IN=7d

# --- Azure AI Document Intelligence (OCR) ---
# Opcional: dejar vacío si no se usa OCR real
AZURE_OCR_ENDPOINT=
AZURE_OCR_KEY=

# --- Google OAuth ---
# Opcional: dejar vacío si no se usa login con Google
GOOGLE_CLIENT_ID=

# --- Google Drive (almacenamiento documental) ---
# Opcional: dejar vacío si no se usa Google Drive
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
